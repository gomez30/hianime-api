{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "node",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "allowJs": true,
    "noEmit": false,
    "types": ["bun-types", "node"]
  },
  "include": ["src", "api"],
  "exclude": ["node_modules", "dist", "index.ts"]
}
